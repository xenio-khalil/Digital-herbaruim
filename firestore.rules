rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return isSignedIn() && userDoc().exists ? userDoc().data.role : '';
    }

    function isAdmin() {
      return userRole() == 'admin';
    }

    function isProfessor() {
      return userRole() == 'professor';
    }

    function isReviewer() {
      return isAdmin() || isProfessor();
    }

    function isPublicPlant(data) {
      return !('status' in data) || data.status == 'approved';
    }

    function isOwner(data) {
      return isSignedIn()
        && data.submittedBy != null
        && data.submittedBy.uid == request.auth.uid;
    }

    function canReadPlant(data) {
      return isPublicPlant(data)
        || isOwner(data)
        || isReviewer();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role in ['student', 'admin'];
      allow update: if isAdmin()
        || (isSignedIn()
            && request.auth.uid == userId
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isAdmin();
    }

    match /plants/{plantId} {
      allow read: if canReadPlant(resource.data);

      allow create: if (isSignedIn()
          && request.resource.data.submittedBy.uid == request.auth.uid
          && request.resource.data.status == 'draft')
        || (isAdmin()
          && request.resource.data.status == 'approved');

      allow update: if isAdmin()
        || (isReviewer()
            && resource.data.status == 'pending'
            && request.resource.data.status in ['pending', 'approved', 'rejected'])
        || (isSignedIn()
            && isOwner(resource.data)
            && resource.data.status in ['draft', 'rejected']
            && request.resource.data.status in ['draft', 'pending']);

      allow delete: if isAdmin()
        || (isSignedIn()
            && isOwner(resource.data)
            && resource.data.status in ['draft', 'rejected']);
    }
  }
}
